{
  "name": "ringierimu/experiments",
  "description": "SDC Experiments Package 🧪",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Gareth Edwards",
      "email": "tools@ringier.co.za"
    }
  ],
  "autoload": {
    "files": [
      "src/helpers.php"
    ],
    "psr-4": {
      "Ringierimu\\Experiments\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ringierimu\\Experiments\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Ringierimu\\Experiments\\ExperimentsServiceProvider"
      ],
      "aliases": {
        "SdcExperiments": "Ringierimu\\Experiments\\Facades\\SdcExperiments"
      }
    }
  },
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "spatie/laravel-googletagmanager": "^2.5"
  },
  "require-dev": {
    "mockery/mockery": "^1.5",
    "phpunit/phpunit": "^10.0|^11.1",
    "orchestra/testbench": "^8.0|^9.0"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "test": "vendor/bin/phpunit"
  }
}
